# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/saveurs-aude?sslmode=verify-full

# Payload CMS
PAYLOAD_SECRET=your-payload-secret-min-32-chars-long

# Vercel Blob Storage (media uploads)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Site URL — must include the Multi-Zones base path (/demo/saveurs-aude).
# Prod: https://dev-oc.fr/demo/saveurs-aude  (NEXT_PUBLIC_* is inlined at build → rebuild on change)
NEXT_PUBLIC_SITE_URL=http://localhost:3000/demo/saveurs-aude
NEXT_PUBLIC_URL=http://localhost:3000/demo/saveurs-aude

# Stripe (payment processing)
SECRET_STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional emails)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=your-resend-audience-id
