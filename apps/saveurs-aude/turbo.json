{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["gen:map", "^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "PAYLOAD_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_URL",
        "VERCEL_BLOB_URL"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": ["RESEND_API_KEY", "CONTACT_EMAIL"]
    },
    "db:migration:check": {
      "cache": false,
      "env": ["PAYLOAD_SECRET"]
    },
    "gen:check": {
      "cache": false,
      "env": ["PAYLOAD_SECRET", "DATABASE_URL"]
    },
    "db:deploy": {
      "cache": false,
      "env": [
        "PAYLOAD_SECRET",
        "DATABASE_URL",
        "POSTGRES_URL",
        "POSTGRES_PRISMA_URL"
      ]
    },
    "gen:map": {
      "dependsOn": ["gen:types"],
      "inputs": ["payload.config.ts", "payload/**"],
      "outputs": ["app/(payload)/admin/importMap.js"],
      "env": ["PAYLOAD_SECRET", "DATABASE_URL"]
    },
    "gen:types": {
      "inputs": ["payload.config.ts", "payload/**"],
      "outputs": ["payload-types.ts"],
      "env": ["PAYLOAD_SECRET", "DATABASE_URL"]
    }
  }
}
