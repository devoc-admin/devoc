{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "browserslist": [
    "Chrome >= 93",
    "Firefox >= 92",
    "Safari >= 15.4",
    "Edge >= 93"
  ],
  "scripts": {
    "dev": "echo \"Network: http://$(ipconfig getifaddr en0):3000\" && bun --bun next dev --turbopack -H 0.0.0.0",
    "inngest": "npx inngest-cli@latest dev",
    "build": "bun --bun next build --turbopack",
    "start": "bun --bun next start",
    "lint": "bun x ultracite fix",
    "format": "biome format --write",
    "create-admin": "bun run scripts/create-admin.ts",
    "seed-prospects": "bun --env-file=.env.local run scripts/seed-prospects.ts",
    "check-types": "tsc --noEmit",
    "db:generate": "bun --env-file=.env.local drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.local drizzle-kit migrate",
    "db:push": "bun --env-file=.env.local drizzle-kit push",
    "db:pull": "bun --env-file=.env.local drizzle-kit pull",
    "db:studio": "bun --env-file=.env.local drizzle-kit studio"
  },
  "dependencies": {
    "@dev-oc/crawler": "workspace:*",
    "@dev-oc/utils": "workspace:*",
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.0.2",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@react-google-maps/api": "^2.20.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.2",
    "class-variance-authority": "catalog:ui",
    "clsx": "catalog:ui",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.2.1",
    "lucide-react": "catalog:ui",
    "motion": "catalog:ui",
    "next": "catalog:next",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "ogl": "^1.0.11",
    "p-limit": "^7.3.0",
    "p-queue": "^9.1.2",
    "pg": "^8.20.0",
    "playwright": "catalog:testing",
    "radix-ui": "^1.4.3",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-scan": "^0.5.3",
