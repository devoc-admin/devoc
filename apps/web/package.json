    "@types/react-dom": "catalog:react",
    "@types/three": "^0.183.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "catalog:tailwind",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:tooling"
