{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL", "NEXT_PUBLIC_SITE_URL", "NEXT_PUBLIC_URL"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": ["RESEND_API_KEY", "CONTACT_EMAIL"]
    }
  }
}
