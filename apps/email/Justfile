set shell := ["zsh", "-c"]

dev:
    bun run dev

build:
    bun run build

clean:
    rm -rf node_modules

lint:
    bun run lint

format:
    bun run format

types:
    bun run types

help:
    echo "Commandes disponibles :"
    just --list

versions:
    just -f "{{justfile_directory()}}/../../Justfile" versions
    echo "(apps/email) react-email: dev server via bun scripts"

install:
    just -f "{{justfile_directory()}}/../../Justfile" install
    bun install
