{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "biome.jsonc",
    "tooling/typescript-config/*.json",
    "package.json",
    "lefthook.yml"
  ],
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": [
    "DOPPLER_TOKEN",
    "DATABASE_URL_UNPOOLED",
    "EDGE_CONFIG",
    "NEON_PROJECT_ID",
    "PGDATABASE",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGPASSWORD",
    "PGUSER",
    "POSTGRES_DATABASE",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_USER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        ".react-email/.next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "types": {
      "dependsOn": ["^types"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!.envrc",
        "!Justfile",
        "!.gitignore"
      ]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
